APP_HOST=127.0.0.1
APP_PORT=8000

DATABASE_URL=mysql+pymysql://media_ai:media_ai@localhost:3306/media_ai?charset=utf8mb4

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_KEEP_ALIVE=30m

CACHE_DIR=./data/cache
THUMBNAIL_DIR=./data/thumbnails
FRAME_CACHE_DIR=./data/video_frames
MAX_IMAGE_LONG_EDGE=1280
DEFAULT_MAX_FRAMES_PER_VIDEO=12
DEFAULT_FRAME_INTERVAL_SECONDS=5
DEFAULT_VIDEO_FRAME_MAX_WIDTH=1280
DEFAULT_VIDEO_BATCH_SIZE=6
OLLAMA_NUM_CTX=32768
# DEFAULT_VIDEO_FRAME_MAX_HEIGHT=720

DEFAULT_VISION_MODEL=qwen2.5vl:7b
DEFAULT_SUMMARY_MODEL=qwen3:8b
DEFAULT_EMBEDDING_MODEL=nomic-embed-text
DEFAULT_EMBEDDING_DIMENSIONS=768

WORKER_POLL_SECONDS=1
SCAN_WORKER_CONCURRENCY=1
METADATA_WORKER_CONCURRENCY=6
VISION_WORKER_CONCURRENCY=1
EMBEDDING_WORKER_CONCURRENCY=2

# JSON array. Include both localhost and 127.0.0.1 because browsers treat them as different origins.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:4173","http://127.0.0.1:4173"]
